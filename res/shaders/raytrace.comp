Hit intersectRay(Ray ray, HitDat hitState, inout LightSampleRec lightSample)
{
    float hitDist = INF;
    float d;
    hitState.hit = false;
    hitState.meshId = -1;

    for (int i = 0; i < numLights; i++)
    {
        float tLight;
        if (intersectLightSphere(ray, lights[i].pos.xyz, tLight))
        {
            if (tLight < hitDist)
            {
                hitState.hit = true;
                hitDist = tLight;

                hitState.meshId = -2;

                hitState.pos = ray.origin + ray.dir * tLight;
                hitState.normal = normalize(hitState.pos - lights[i].pos.xyz);

                float d = length(hitState.pos - lights[i].pos.xyz);
                hitState.mat.alpha = exp(-(d * d) / (LIGHT_RAD * LIGHT_RAD));
                hitState.mat.alphaMode = 1;
            }
        }
    }

    for (int m = 0; m < numMeshes; m++)
    {
        vec3 bmin = bvhAaBb[m].minBounds.xyz;
        vec3 bmax = bvhAaBb[m].maxBounds.xyz;

        float tmin, tmax;
        if (!intersectAABB(ray, bmin, bmax, tmin, tmax))
            continue;

        int first = bvhNodes[m].firstIndex;
        int count = bvhNodes[m].triCount;

        //IMPLEMENT HERE WHEN READY
        Transform transMat;
        //CREATE NEW RAY FOR TRANSOFRMED CHECK
        for (int i = 0; i < count; i++)
        {
            int baseIdx = (first + i) * 3;

            uint i0 = indices[baseIdx + 0];
            uint i1 = indices[baseIdx + 1];
            uint i2 = indices[baseIdx + 2];

            vec3 v0 = vertexData[i0].position.xyz;
            vec3 v1 = vertexData[i1].position.xyz;
            vec3 v2 = vertexData[i2].position.xyz;

            float t;
            vec3 bary;

            if (intersectTriangle(ray, v0, v1, v2, t, bary))
            {
                if (t < hitDist)
                {
                    hitState.hit = true;
                    hitDist = t;
                    hitState.meshId = m;

                    hitState.pos = ray.origin + ray.dir * hitDist;

                    vec3 n0 = vertexData[i0].normal.xyz;
                    vec3 n1 = vertexData[i1].normal.xyz;
                    vec3 n2 = vertexData[i2].normal.xyz;

                    hitState.normal = normalize(n0 * bary.x + n1 * bary.y + n2 * bary.z);

                    vec2 uv0 = vertexData[i0].uv.xy;
                    vec2 uv1 = vertexData[i1].uv.xy;
                    vec2 uv2 = vertexData[i2].uv.xy;

                    hitState.texCoord = uv0 * bary.x + uv1 * bary.y + uv2 * bary.z;

                    vec3 t0 = vertexData[i0].tangent.xyz;
                    vec3 t1 = vertexData[i1].tangent.xyz;
                    vec3 t2 = vertexData[i2].tangent.xyz;
                    
                    hitState.tangent = t0 * bary.x + t1 * bary.y + t2 * bary.z;

                    vec3 bt0 = vertexData[i0].bitangent.xyz;
                    vec3 bt1 = vertexData[i1].bitangent.xyz;
                    vec3 bt2 = vertexData[i2].bitangent.xyz;
                    
                    hitState.bitangent = bt0 * bary.x + bt1 * bary.y + bt2 * bary.z;
                }
            }
        }
    }

    // prevent light through wall
    if (hitState.hit) { hitState.pos -= normalize(ray.dir); };
    return hitState;
}

Hit isInShadow(vec3 pos, vec3 lightPos)
{
    vec3 dir = lightPos - pos;
    float maxDist = length(dir);
    dir /= maxDist;

    Ray shadowRay;
    shadowRay.origin = pos + dir * 0.001;
    shadowRay.dir = dir;

    return intersectRay(shadowRay);
};

vec3 UniformSampleHemisphere(float r1, float r2)
{
    float r = sqrt(max(0.0, 1.0 - r1 * r1));
    float phi = 2.0 * PI * r2;
    return vec3(r * cos(phi), r * sin(phi), r1);
}

void Onb(in vec3 N, inout vec3 T, inout vec3 B)
{
    vec3 up = abs(N.z) < 0.9999999 ? vec3(0, 0, 1) : vec3(1, 0, 0);
    T = normalize(cross(up, N));
    B = cross(N, T);
}

vec3 EvalTransmittance(Ray r)
{
    LightSampleRec lightSample;
    HitDat state;
    vec3 transmittance = vec3(1.0);

    for (int depth = 0; depth < MAX_DEPTH; depth++)
    {
        bool hit = intersectRay(r, state, lightSample);

        // If no hit (environment map) or if ray hit a light source then return transmittance
        if (!hit || state.isEmitter)
            break;

        getMaterial(state);

        bool alphatest = ((state.mat.alphaMode == 0 && state.mat.opacity < state.mat.alphaCutoff) || (state.mat.alphaMode == 1 && rand() > state.mat.opacity));
        bool refractive = (1.0 - state.mat.metallic) * state.mat.specTrans > 0.0;

        // Refraction is ignored (Not physically correct but helps with sampling lights from inside refractive objects)
        if (hit && !(alphatest || refractive))
            return vec3(0.0);

        // Evaluate transmittance
        /* REWORK FOR SEE THORUGH
        if (dot(r.direction, state.normal) > 0 && state.mat.medium.type != MEDIUM_NONE)
        {
            vec3 color = state.mat.medium.type == MEDIUM_ABSORB ? vec3(1.0) - state.mat.medium.color : vec3(1.0);
            transmittance *= exp(-color * state.mat.medium.density * state.hitDist);
        }*/

        // Move ray origin to hit point
        r.origin = state.pos + r.dir * EPS;
    }

    return transmittance;
}


void SampleSphereLight(int lightIndex, in vec3 scatterPos, inout LightSampleRec lightSample)
{
    uvec4 rand = rand4(seed);

    float r1 = rand.x;
    float r2 = rand.y;

    vec3 sphereCentertoSurface = scatterPos - lights[lightIndex].pos.xyz;
    float distToSphereCenter = length(sphereCentertoSurface);
    vec3 sampledDir;

    // TODO: Fix this. Currently assumes the light will be hit only from the outside
    sphereCentertoSurface /= distToSphereCenter;
    sampledDir = UniformSampleHemisphere(r1, r2);
    vec3 T, B;
    Onb(sphereCentertoSurface, T, B);
    sampledDir = T * sampledDir.x + B * sampledDir.y + sphereCentertoSurface * sampledDir.z;

    vec3 lightSurfacePos = lights[lightIndex].pos.xyz + sampledDir * LIGHT_RAD;

    lightSample.direction = lightSurfacePos - scatterPos;
    lightSample.dist = length(lightSample.direction);
    float distSq = lightSample.dist * lightSample.dist;

    lightSample.direction /= lightSample.dist;
    lightSample.normal = normalize(lightSurfacePos - lights[lightIndex].pos.xyz);
    lightSample.emission = lights[lightIndex].color.rgb * lights[lightIndex].color.a;
    lightSample.pdf = distSq / (light.area * 0.5 * abs(dot(lightSample.normal, lightSample.direction)));
}


vec3 computeDirectLight(Hit hitState, Ray ray)
{
    LightSampleRec lightSample;
    vec3 scatterPos = hitState.pos + hitState.normal * EPS;

    vec3 result = vec3(0.0);

    float specPower = 32;
    float transparency_power = 1.0;

    for (int i = 0; i < numLights; i++)
    {
        SampleSphereLight(i, scatterPos, lightSample);
        Li = lightSample.emission;
        result += lightCol * diffuse + specular;
        Ray shadowRay;
        shadowRay.origin = scatterPos;
        shadowRay.dir = lightSample.direction;
        Hit shadowHit = isInShadow(scatterPos, lights[i].pos.xyz);
        if (shadowHit.hit && shadowHit.t < length(light_vector))
            continue;
        float norm_dot_light = max(dot(normal, light_dir), 0.0);
        vec3 diffuse = albedo * norm_dot_light;

        vec3 light_vector = lights[i].pos.xyz - hitState.pos;
        float light_distance = length(light_vector);
        float attenuation = lights[i].color.a / (light_distance * light_distance);

        vec3 lightCol = lights[i].color.rgb * attenuation;

        vec3 R = reflect(-light_dir, normal);
        float spec = pow(max(dot(viewDir, R), 0.0), specPower);

        vec3 specular = lightCol * spec * 0.5;

        result += (lightCol * diffuse + specular);
    }
    return result;
}
