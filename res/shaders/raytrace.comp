// Ray-triangle intersection
// Moller–Trumbore
bool intersectTriangle(Ray ray, vec3 v0, vec3 v1, vec3 v2, out float t, out vec3 bary) {
    vec3 e1 = v1 - v0;
    vec3 e2 = v2 - v0;

    vec3 p = cross(ray.dir, e2);
    float det = dot(e1, p);

    if (abs(det) < EPS) return false;

    float invDet = 1.0 / det;

    vec3 tvec = ray.origin - v0;
    float u = dot(tvec, p) * invDet;
    if (u < 0.0 || u > 1.0) return false;

    vec3 q = cross(tvec, e1);
    float v = dot(ray.dir, q) * invDet;
    if (v < 0.0 || (u + v) > 1.0) return false;

    t = dot(e2, q) * invDet;
    bary = vec3(1.0 - u - v, u, v);

    return t > EPS;
};

bool intersectLightSphere(Ray ray, vec3 center, out float t)
{
    vec3 oc = ray.origin - center;

    float a = dot(ray.dir, ray.dir);
    float b = 2.0 * dot(oc, ray.dir);
    float c = dot(oc, oc) - LIGHT_RAD * LIGHT_RAD;

    float discriminant = b * b - 4.0 * a * c;
    if (discriminant < 0.0) return false;

    float s = sqrt(discriminant);
    float t0 = (-b - s) / (2.0 * a);
    float t1 = (-b + s) / (2.0 * a);

    t = (t0 > 0.001) ? t0 : t1;
    return t > 0.001;
};

// Helper funcs
vec3 RayAt(Ray r, float t)
{
    return r.origin + r.dir * t;
}

vec3 reject(vec3 from, vec3 onto) {
    return from - onto * dot(from, onto) / dot(onto, onto);
}



vec4 getTexture(HitDat hit)
{
    vec4 tex = texture(
        texArray,
        vec3(hit.texCoord, bvhNodes[hit.meshId].texId)
    );

    if (dot(tex, tex) < 0.0001)
        tex = vec4(0.6, 0.6, 0.65, 1.0);

    return tex;
}

vec3 getNormals(HitDat hit)
{
    vec3 norm = texture(
        normalsArray,
        vec3(hit.texCoord, bvhNodes[hit.meshId].texId)
    ).rgb;

    norm = (norm * 2.0) - 1.0;

    if (dot(norm, norm) < 0.0001)
        norm = vec3(0.6, 0.6, 0.65);

    return normalize(norm);
};

void getMaterial(inout HitDat hit) {
    // FILL MATERIAL DETAILS HERE
    if (hit.meshId > 0) {
        vec4 baseCol = getTexture(hit);
        hit.mat.baseColor = baseCol.rgb;
        hit.mat.opacity = baseCol.a;
        hit.mat.alphaMode = 0; //Cutoff
        hit.mat.alphaCutoff = 0.05;

        vec3 normalMap = getNormals(hit);

        mat3 tbn = mat3(
            normalize(hit.tangent.xyz),
            normalize(hit.bitangent.xyz),
            normalize(hit.normal));

        hit.normal = normalize(tbn * normalMap);
    }
}

//https://stackoverflow.com/questions/69510208/path-tracing-cosine-hemisphere-sampling-and-emissive-objects
uvec4 rng_initialize(vec2 p, int frame)
{
    return uvec4(p, frame, p.x + p.y);
};

void pcg4d(inout uvec4 v)
{
    v = v * 1664525u + 1013904223u;
    v.x += v.y * v.w;
    v.y += v.z * v.x;
    v.z += v.x * v.y;
    v.w += v.y * v.z;
    v = v ^ (v >> 16u);
    v.x += v.y * v.w;
    v.y += v.z * v.x;
    v.z += v.x * v.y;
    v.w += v.y * v.z;
};
vec3 rand3(uvec4 seed)
{
    pcg4d(seed);
    return vec3(seed.xyz) / float(0xffffffffu);
};

uvec4 rand4(uvec4 seed)
{
    pcg4d(seed);
    return uvec4(seed / float(0xffffffffu));
};

